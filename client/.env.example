# Copy this file to .env.local for local development overrides
# client/.env.example

# API base URL — set this for Capacitor (mobile) and Electron (desktop) builds
# Leave unset for web (Vite dev proxy handles it automatically)
# VITE_API_URL=https://your-server.com/api

# For Capacitor live-reload during mobile development:
# VITE_API_URL=http://192.168.1.x:3001/api

# WebRTC TURN server credentials (required for calls across symmetric NAT / firewalls)
# Without these, calls only work over STUN (local network / non-restricted NAT).
# Get free credentials from https://www.metered.ca/tools/openrelay/ or use Twilio / coturn.
# VITE_TURN_URL=turn:openrelay.metered.ca:80
# VITE_TURN_USERNAME=your_turn_username
# VITE_TURN_CREDENTIAL=your_turn_credential
