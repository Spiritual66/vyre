# Copy this file to .env and fill in your values
# server/.env

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change_me_in_production_use_a_random_64_char_string

# Comma-separated list of allowed CORS origins
# Leave unset to allow only localhost dev origins
# ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com

# Server port (default: 3001)
# PORT=3001

# Set to "production" when running in production
# NODE_ENV=production

# ── Email (password reset) ─────────────────────────────────
# Public app URL used to build reset links (defaults to the request origin)
# APP_URL=https://your-app.com
# SMTP — when unset, password-reset links are logged to the server console
# (dev) instead of emailed.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# SMTP_FROM="VYRE <no-reply@your-app.com>"

# ── AI Writing Tools — pick any ONE provider ───────────────
# Option 1 (FREE): Google Gemini Flash — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Option 2 (FREE): Groq / Llama 3.1 — https://console.groq.com/keys
# GROQ_API_KEY=

# Option 3 (PAID): Anthropic Claude Haiku — https://console.anthropic.com/
# ANTHROPIC_API_KEY=
